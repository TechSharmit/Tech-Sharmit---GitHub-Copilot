# Program Name : employee_ranking.py
# Scenario     : A corporate HR system that ranks employees
#                based on performance score, salary, experience
#                and department using lambda inside sorted()
#                to produce various leaderboard reports.
# ============================================================


def rank_employees() -> None:
    """
    Sorts and ranks employee records using multiple
    lambda functions inside sorted() calls to generate
    different HR performance reports.
    """

    # ----------------------------------------------------------
    # Raw employee data — list of dictionaries
    # ----------------------------------------------------------
    employees = [
        {"name": "Ramesh Kumar",  "dept": "Sales",     "salary": 55000,
         "score": 88, "experience": 5},
        {"name": "Sunita Devi",   "dept": "Tech",      "salary": 72000,
         "score": 92, "experience": 8},
        {"name": "Ajay Sharma",   "dept": "Sales",     "salary": 48000,
         "score": 76, "experience": 3},
        {"name": "Priya Patel",   "dept": "HR",        "salary": 51000,
         "score": 88, "experience": 6},
        {"name": "Mohit Verma",   "dept": "Tech",      "salary": 85000,
         "score": 95, "experience": 10},
        {"name": "Neha Gupta",    "dept": "HR",        "salary": 47000,
         "score": 70, "experience": 2},
        {"name": "Vikram Singh",  "dept": "Tech",      "salary": 91000,
         "score": 95, "experience": 12},
        {"name": "Ritu Agarwal",  "dept": "Sales",     "salary": 62000,
         "score": 83, "experience": 7},
    ]

    # ----------------------------------------------------------
    # Sort 1: Sort by Performance Score — Highest First
    # Lambda picks score field, reverse=True for descending
    # ----------------------------------------------------------
    by_score = sorted(employees,
                      key    = lambda emp: emp["score"],
                      reverse= True)

    print("=" * 65)
    print("  🏆  SORT 1 — BY PERFORMANCE SCORE (Highest First)")
    print("=" * 65)
    print(f"  {'Rank':<6} {'Name':<18} {'Dept':<10} {'Score'}")
    print("-" * 65)
    for rank, emp in enumerate(by_score, start=1):
        print(f"  {rank:<6} {emp['name']:<18} {emp['dept']:<10} {emp['score']}")

    # ----------------------------------------------------------
    # Sort 2: Sort by Salary — Lowest First (ascending default)
    # Lambda picks salary field, no reverse so ascending order
    # ----------------------------------------------------------
    by_salary = sorted(employees,
                       key = lambda emp: emp["salary"])

    print("\n" + "=" * 65)
    print("  💰  SORT 2 — BY SALARY (Lowest to Highest)")
    print("=" * 65)
    print(f"  {'Rank':<6} {'Name':<18} {'Dept':<10} {'Salary (₹)'}")
    print("-" * 65)
    for rank, emp in enumerate(by_salary, start=1):
        print(f"  {rank:<6} {emp['name']:<18} {emp['dept']:<10} "
              f"₹ {emp['salary']:,}")

    # ----------------------------------------------------------
    # Sort 3: Sort by Name Alphabetically — A to Z
    # Lambda picks name field and converts to lowercase
    # to ensure case-insensitive alphabetical sorting
    # ----------------------------------------------------------
    by_name = sorted(employees,
                     key = lambda emp: emp["name"].lower())

    print("\n" + "=" * 65)
    print("  🔤  SORT 3 — BY NAME (A to Z Alphabetical)")
    print("=" * 65)
    print(f"  {'Rank':<6} {'Name':<18} {'Dept'}")
    print("-" * 65)
    for rank, emp in enumerate(by_name, start=1):
        print(f"  {rank:<6} {emp['name']:<18} {emp['dept']}")

    # ----------------------------------------------------------
    # Sort 4: Multi-Key Sort — By Department A to Z,
    #         then by Score Highest First within same department
    # Lambda returns a tuple: (dept ascending, score descending)
    # Minus sign on score flips it to descending in the tuple
    # ----------------------------------------------------------
    by_dept_score = sorted(employees,
                           key = lambda emp: (emp["dept"],
                                              -emp["score"]))

    print("\n" + "=" * 65)
    print("  🏢  SORT 4 — BY DEPARTMENT then SCORE (Multi-Key)")
    print("=" * 65)
    print(f"  {'Rank':<6} {'Name':<18} {'Dept':<10} {'Score'}")
    print("-" * 65)
    for rank, emp in enumerate(by_dept_score, start=1):
        print(f"  {rank:<6} {emp['name']:<18} {emp['dept']:<10} {emp['score']}")

    # ----------------------------------------------------------
    # Sort 5: Multi-Key Sort — By Experience Descending,
    #         then Salary Descending for same experience level
    # Both keys negated to achieve descending on both fields
    # ----------------------------------------------------------
    by_exp_salary = sorted(employees,
                           key = lambda emp: (-emp["experience"],
                                              -emp["salary"]))

    print("\n" + "=" * 65)
    print("  📅  SORT 5 — BY EXPERIENCE then SALARY (Both Descending)")
    print("=" * 65)
    print(f"  {'Rank':<6} {'Name':<18} {'Exp (Yrs)':<12} {'Salary (₹)'}")
    print("-" * 65)
    for rank, emp in enumerate(by_exp_salary, start=1):
        print(f"  {rank:<6} {emp['name']:<18} {emp['experience']:<12} "
              f"₹ {emp['salary']:,}")

    print("=" * 65)


# -------------------------------------------------------
# Main Program
# -------------------------------------------------------
if __name__ == "__main__":
    rank_employees()



