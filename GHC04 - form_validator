import re


def validate_user_form(name: str, email: str, phone: str,
                       dob: str, pincode: str) -> dict:
    """
    Validates hospital patient registration form fields
    using regular expression patterns.

    Args:
        name     (str): Full name of the patient.
        email    (str): Email address of the patient.
        phone    (str): 10-digit mobile number.
        dob      (str): Date of birth in DD-MM-YYYY format.
        pincode  (str): 6-digit Indian postal pincode.

    Returns:
        dict: Validation result for each field with status and message.
    """

    results = {}

    # -------------------------------------------------------
    # Pattern 1: Full Name
    # Only alphabets and single spaces allowed, min 3 characters
    # -------------------------------------------------------
    name_pattern = r"^[A-Za-z]+(?: [A-Za-z]+)*$"
    if re.fullmatch(name_pattern, name.strip()) and len(name.strip()) >= 3:
        results["name"] = {"status": "✅ Valid", "message": "Name is valid."}
    else:
        results["name"] = {"status": "❌ Invalid", "message": "N`ame must contain only alphabets and spaces, min 3 characters."}

    # -------------------------------------------------------
    # Pattern 2: Email Address
    # Standard email format: characters @ domain . extension
    # -------------------------------------------------------
    email_pattern = r"^[\w\.-]+@[\w\.-]+\.[a-zA-Z]{2,6}$"
    if re.fullmatch(email_pattern, email.strip()):
        results["email"] = {"status": "✅ Valid", "message": "Email is valid."}
    else:
        results["email"] = {"status": "❌ Invalid", "message": "Enter a valid email like user@example.com."}

    # -------------------------------------------------------
    # Pattern 3: Phone Number
    # 10-digit Indian mobile number starting with 6, 7, 8, or 9
    # -------------------------------------------------------
    phone_pattern = r"^[6-9]\d{9}$"
    if re.fullmatch(phone_pattern, phone.strip()):
        results["phone"] = {"status": "✅ Valid", "message": "Phone number is valid."}
    else:
        results["phone"] = {"status": "❌ Invalid", "message": "Phone must be 10 digits starting with 6, 7, 8, or 9."}

    # -------------------------------------------------------
    # Pattern 4: Date of Birth
    # Format: DD-MM-YYYY (e.g., 15-08-1995)
    # -------------------------------------------------------
    dob_pattern = r"^(0[1-9]|[12]\d|3[01])-(0[1-9]|1[0-2])-\d{4}$"
    if re.fullmatch(dob_pattern, dob.strip()):
        results["dob"] = {"status": "✅ Valid", "message": "Date of birth is valid."}
    else:
        results["dob"] = {"status": "❌ Invalid", "message": "Date must be in DD-MM-YYYY format like 15-08-1995."}

    # -------------------------------------------------------
    # Pattern 5: Pincode
    # 6-digit Indian postal pincode, cannot start with 0
    # -------------------------------------------------------
    pincode_pattern = r"^[1-9]\d{5}$"
    if re.fullmatch(pincode_pattern, pincode.strip()):
        results["pincode"] = {"status": "✅ Valid", "message": "Pincode is valid."}
    else:
        results["pincode"] = {"status": "❌ Invalid", "message": "Pincode must be 6 digits and cannot start with 0."}

    return results


