def calculate_team_bonus(employee: dict, level: int = 0) -> int:
    """
    Recursively calculates the total bonus for an employee
    including all subordinates below them in the hierarchy.

    Args:
        employee (dict): Employee node with name, bonus, subordinates.
        level    (int) : Current depth level in hierarchy (default 0).

    Returns:
        int: Total bonus amount for this employee and entire team below.
    """

    # Step 1: Get the individual bonus of current employee
    total_bonus = employee["bonus"]

    # Step 2: Print current employee with indentation showing level
    indent = "    " * level
    print(f"{indent}📌 {employee['name']} — Individual Bonus: ₹ {employee['bonus']:,}")

    # Step 3: BASE CASE — if no subordinates, return own bonus only
    if not employee["subordinates"]:
        print(f"{indent}   └── No team members. Bonus = ₹ {total_bonus:,}")
        return total_bonus

    # Step 4: RECURSIVE CASE — loop through each subordinate
    #         and recursively calculate their total team bonus
    for subordinate in employee["subordinates"]:
        total_bonus += calculate_team_bonus(subordinate, level + 1)

    # Step 5: Print total bonus for this employee including full team
    print(f"{indent}   └── Total Team Bonus for {employee['name']} = ₹ {total_bonus:,}")

    return total_bonus


