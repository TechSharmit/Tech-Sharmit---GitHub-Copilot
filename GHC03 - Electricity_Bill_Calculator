import sys
sys.stdout.reconfigure(encoding='utf-8')

def calculate_electricity_bill(units_consumed: int, is_rural: bool = False) -> dict:
    """
    Calculates the monthly electricity bill based on units consumed.

    Args:
        units_consumed (int): Total electricity units used in a month.
        is_rural (bool): If True, applies 10% rural subsidy. Default is False.

    Returns:
        dict: Detailed bill with slab charges, subsidy, tax, and final amount.
    """

    # Step 1: Define slab rates (cost per unit based on consumption range)
    if units_consumed <= 100:
        energy_charge = units_consumed * 3.50

    elif units_consumed <= 300:
        energy_charge = (100 * 3.50) + ((units_consumed - 100) * 5.00)

    else:
        energy_charge = (100 * 3.50) + (200 * 5.00) + ((units_consumed - 300) * 7.50)

    # Step 2: Add fixed meter rent charge
    meter_rent = 50.00

    # Step 3: Calculate subtotal before subsidy and tax
    subtotal = energy_charge + meter_rent

    # Step 4: Apply rural subsidy of 10% if applicable
    subsidy = round(subtotal * 0.10, 2) if is_rural else 0.00

    # Step 5: Calculate amount after subsidy deduction
    amount_after_subsidy = subtotal - subsidy

    # Step 6: Apply 5% government tax on final amount
    tax = round(amount_after_subsidy * 0.05, 2)

    # Step 7: Calculate total payable amount
    total_payable = round(amount_after_subsidy + tax, 2)

    # Step 8: Return complete bill breakdown
    return {
        "units_consumed"    : units_consumed,
        "energy_charge"     : round(energy_charge, 2),
        "meter_rent"        : meter_rent,
        "subtotal"          : round(subtotal, 2),
        "rural_subsidy"     : subsidy,
        "amount_after_subsidy": round(amount_after_subsidy, 2),
        "govt_tax_5_percent": tax,
        "total_payable"     : total_payable
    }


