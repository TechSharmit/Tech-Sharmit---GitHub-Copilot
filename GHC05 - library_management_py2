def manage_library(member_name, books_borrowed, days_late, is_premium):

    # Step 1: Print welcome message (Python 2 print statement)
    print "===== Library Management System ====="
    print "Processing member:", member_name

    # Step 2: Calculate fine using integer division (Python 2 behavior)
    fine_per_day = 5
    total_fine = fine_per_day * days_late / 2

    # Step 3: Apply premium discount using old division result
    if is_premium:
        discount = total_fine / 4
        total_fine = total_fine - discount
        print "Premium Discount Applied:", discount

    # Step 4: Check borrowing limit using Python 2 integer comparison
    max_books = 5
    if books_borrowed > max_books:
        print "Warning: Book limit exceeded by", books_borrowed - max_books

    # Step 5: Display member type using Python 2 unicode string
    member_type = u"Premium Member" if is_premium else u"Regular Member"
    print "Member Type:", member_type

    # Step 6: Build summary using old-style string formatting
    summary = "Member: %s | Books: %d | Fine: %d | Type: %s" % (
               member_name, books_borrowed, total_fine, member_type)
    print summary

    # Step 7: Return summary using has_key() (Python 2 dict method)
    result = {}
    result["member_name"]   = member_name
    result["books_borrowed"] = books_borrowed
    result["total_fine"]    = total_fine
    result["member_type"]   = member_type

    if result.has_key("total_fine"):
        print "Fine calculation confirmed."

    return result


