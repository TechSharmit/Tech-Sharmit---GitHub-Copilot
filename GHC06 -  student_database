import sqlite3


def manage_student_database():
    """
    Performs all database operations for the school
    student management system including creating table,
    inserting records, updating marks, deleting records,
    and fetching student reports.
    """

    # ----------------------------------------------------------
    # DB Interaction 1: Connect to SQLite Database
    # Creates database file if it does not exist
    # ----------------------------------------------------------
    connection = sqlite3.connect("school.db")
    cursor     = connection.cursor()

    # ----------------------------------------------------------
    # DB Interaction 2: CREATE TABLE
    # Creates students table if it does not already exist
    # ----------------------------------------------------------
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS students (
            student_id   INTEGER PRIMARY KEY AUTOINCREMENT,
            name         TEXT    NOT NULL,
            class        TEXT    NOT NULL,
            marks        REAL    NOT NULL,
            is_active    INTEGER DEFAULT 1
        )
    """)
    connection.commit()

    # ----------------------------------------------------------
    # DB Interaction 3: INSERT Records
    # Inserts multiple student records into the table
    # ----------------------------------------------------------
    students_data = [
        ("Ramesh Kumar",  "10-A", 88.5),
        ("Sunita Devi",   "10-B", 91.0),
        ("Ajay Sharma",   "10-A", 74.0),
        ("Priya Patel",   "10-B", 95.5),
        ("Mohit Verma",   "10-A", 61.0)
    ]

    cursor.executemany("""
        INSERT INTO students (name, class, marks)
        VALUES (?, ?, ?)
    """, students_data)
    connection.commit()

    # ----------------------------------------------------------
    # DB Interaction 4: SELECT All Records
    # Fetches all student records from the table
    # ----------------------------------------------------------
    cursor.execute("SELECT * FROM students")
    all_students = cursor.fetchall()

    print("=" * 60)
    print("       📋  ALL STUDENT RECORDS")
    print("=" * 60)
    print(f"  {'ID':<5} {'Name':<18} {'Class':<8} {'Marks':<8} {'Active'}")
    print("-" * 60)
    for student in all_students:
        print(f"  {student[0]:<5} {student[1]:<18} {student[2]:<8} "
              f"{student[3]:<8} {student[4]}")

    # ----------------------------------------------------------
    # DB Interaction 5: UPDATE Record
    # Updates marks for a specific student by name
    # ----------------------------------------------------------
    cursor.execute("""
        UPDATE students
        SET marks = ?
        WHERE name = ?
    """, (97.0, "Ajay Sharma"))
    connection.commit()
    print("\n  ✅ Marks updated for Ajay Sharma to 97.0")

    # ----------------------------------------------------------
    # DB Interaction 6: SELECT Top Performers
    # Fetches students scoring above 85 marks ordered by marks
    # ----------------------------------------------------------
    cursor.execute("""
        SELECT name, class, marks
        FROM students
        WHERE marks > ?
        ORDER BY marks DESC
    """, (85,))
    top_students = cursor.fetchall()

    print("\n" + "=" * 60)
    print("       🏆  TOP PERFORMING STUDENTS (Marks > 85)")
    print("=" * 60)
    print(f"  {'Name':<18} {'Class':<8} {'Marks'}")
    print("-" * 60)
    for student in top_students:
        print(f"  {student[0]:<18} {student[1]:<8} {student[2]}")

    # ----------------------------------------------------------
    # DB Interaction 7: DELETE Record
    # Marks a student as inactive (soft delete)
    # ----------------------------------------------------------
    cursor.execute("""
        UPDATE students
        SET is_active = ?
        WHERE name = ?
    """, (0, "Mohit Verma"))
    connection.commit()
    print("\n  ✅ Mohit Verma marked as inactive.")

    # ----------------------------------------------------------
    # DB Interaction 8: SELECT Active Students Only
    # Fetches only students where is_active = 1
    # ----------------------------------------------------------
    cursor.execute("""
        SELECT name, class, marks
        FROM students
        WHERE is_active = ?
    """, (1,))
    active_students = cursor.fetchall()

    print("\n" + "=" * 60)
    print("       ✅  ACTIVE STUDENTS ONLY")
    print("=" * 60)
    for student in active_students:
        print(f"  {student[0]:<18} {student[1]:<8} {student[2]}")

    # ----------------------------------------------------------
    # DB Interaction 9: DROP TABLE
    # Cleans up the table after demo is complete
    # ----------------------------------------------------------
    cursor.execute("DROP TABLE IF EXISTS students")
    connection.commit()

    # ----------------------------------------------------------
    # DB Interaction 10: CLOSE Connection
    # Releases database connection and frees resources
    # ----------------------------------------------------------
    connection.close()
    print("\n  ✅ Database connection closed successfully.")
    print("=" * 60)


# -------------------------------------------------------
# Main Program
# -------------------------------------------------------
if __name__ == "__main__":
    manage_student_database()
