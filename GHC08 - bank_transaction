import time
import functools
from datetime import datetime


# ----------------------------------------------------------
# THE DECORATOR — transaction_monitor
# Wraps any bank transaction function to add:
#   - Security check before transaction
#   - Execution time measurement
#   - Audit log entry before and after
#   - Error handling and alerting
# ----------------------------------------------------------
def transaction_monitor(func):

    @functools.wraps(func)
    def wrapper(*args, **kwargs):

        # ------------------------------------------------
        # BEFORE THE FUNCTION RUNS
        # ------------------------------------------------

        # Step 1: Capture transaction start time
        start_time = time.time()

        # Step 2: Get current timestamp for audit log
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

        # Step 3: Extract account and amount from arguments
        account_number = args[0] if args else "Unknown"
        amount         = args[1] if len(args) > 1 else 0

        # Step 4: Print audit log entry — transaction started
        print("=" * 55)
        print(f"  🔐 TRANSACTION MONITOR — AUDIT LOG")
        print("=" * 55)
        print(f"  ▶ Timestamp       : {timestamp}")
        print(f"  ▶ Function Called : {func.__name__}")
        print(f"  ▶ Account Number  : {account_number}")
        print(f"  ▶ Amount          : ₹ {amount:,}")
        print(f"  ▶ Status          : INITIATED")
        print("-" * 55)

        # Step 5: Security check — block transactions above limit
        if amount > 100000:
            print(f"  🚨 SECURITY ALERT : Amount exceeds ₹ 1,00,000 limit!")
            print(f"  ❌ Transaction BLOCKED by monitor.")
            print("=" * 55)
            return None

        # ------------------------------------------------
        # CALL THE ORIGINAL FUNCTION
        # ------------------------------------------------
        try:
            result = func(*args, **kwargs)
            status = "SUCCESS"

        except Exception as e:
            result = None
            status = f"FAILED — {str(e)}"

        # ------------------------------------------------
        # AFTER THE FUNCTION RUNS
        # ------------------------------------------------

        # Step 6: Calculate total execution time
        end_time       = time.time()
        execution_time = round((end_time - start_time) * 1000, 2)

        # Step 7: Print audit log entry — transaction completed
        print(f"  ✅ Status          : {status}")
        print(f"  ⏱  Execution Time  : {execution_time} ms")
        print(f"  🔒 Monitor         : Transaction audit complete.")
        print("=" * 55)

        # Step 8: Return the original function result
        return result

    return wrapper


# ----------------------------------------------------------
# THE DECORATED FUNCTION — process_withdrawal
# Actual bank withdrawal logic wrapped by transaction_monitor
# ----------------------------------------------------------
@transaction_monitor
def process_withdrawal(account_number: str,
                       amount: float,
                       balance: float) -> dict:
    """
    Processes a bank withdrawal request after
    validating sufficient balance.

    Args:
        account_number (str)  : Customer bank account number.
        amount         (float): Amount to withdraw.
        balance        (float): Current account balance.

    Returns:
        dict: Transaction result with updated balance and status.
    """

    # Step 1: Validate sufficient balance
    if amount > balance:
        raise ValueError(f"Insufficient balance. "
                         f"Available: ₹ {balance:,}, "
                         f"Requested: ₹ {amount:,}")

    # Step 2: Deduct withdrawal amount from balance
    updated_balance = balance - amount

    # Step 3: Print transaction details
    print(f"  💳 Processing withdrawal for Account: {account_number}")
    print(f"  💰 Amount Withdrawn  : ₹ {amount:,}")
    print(f"  🏦 Closing Balance   : ₹ {updated_balance:,}")

    # Step 4: Return transaction result
    return {
        "account_number"  : account_number,
        "amount_withdrawn": amount,
        "closing_balance" : updated_balance,
        "status"          : "Withdrawal Successful"
    }


